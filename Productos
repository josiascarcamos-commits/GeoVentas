<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GeoVentas | Nuestros Productos</title>
    <link rel="stylesheet" href="style.css">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;900&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>
    <nav class="navbar">
        <div class="logo-container">
            <span class="brand">GeoVentas</span>
        </div>
        <div class="nav-links">
            <a href="index.html">Inicio</a>
        </div>
    </nav>

    <section class="container">
        <h2 class="section-title">Nuestros Productos</h2>
        <div class="promo-grid">
            
            <div class="promo-card">
                <div class="status-tags"><span class="tag-ok">✅ Disponible</span></div>
                <div class="img-placeholder">FOTO PRODUCTO</div>
                <h3>Cargador Ugreen 65W</h3>
                <div class="prices">
                    <span class="new">$00.000</span>
                </div>
                <div class="stock-bar"><div class="stock-progress" style="width: 80%;"></div></div>
                <a href="https://wa.me/56929142859" class="btn-wa-promo">Comprar</a>
            </div>

        </div>
    </section>
<footer id="contact" class="footer">
  <div class="footer-content">
    <!-- SECCIÓN SÍGUENOS -->
    <div class="follow-section">
      <h3 class="follow-title gradient-gold">SÍGUENOS</h3>
      <div class="footer-socials">
        <a href="https://instagram.com/geoventas" target="_blank" class="footer-social-icon" title="Instagram">
          <i class="fab fa-instagram"></i>
          <span class="sr-only">Instagram</span>
        </a>
        <a href="https://facebook.com/geoventas" target="_blank" class="footer-social-icon" title="Facebook">
          <i class="fab fa-facebook-f"></i>
          <span class="sr-only">Facebook</span>
        </a>
      </div>
    </div>

    <!-- LOGO Y UBICACIÓN -->
    <div class="footer-logo gradient-gold">GeoVentas</div>
    <p style="color: var(--text-secondary); margin-bottom: 1.5rem;">Hualpén/Concepción - Chile</p>
    
    <!-- COPYRIGHT -->
    <div class="footer-location">
      <p style="color: var(--text-secondary); font-size: 0.9rem;">
        © 2024 GeoVentas. Todos los derechos reservados. | Hualpén, Concepción, Chile
      </p>
    </div>
  </div>
</footer>
</body>
</html>
