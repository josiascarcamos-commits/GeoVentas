    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* CSS COMPLETO - MISMO ESTILO LUXURY NEGRO Y ORO */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --black-primary: #050505;
            --black-deep: #0a0a0a;
            --gold-primary: #f9e27d;
            --gold-dark: #d4af37;
            --gold-glow: rgba(249, 226, 125, 0.6);
            --white-soft: rgba(255, 255, 255, 0.9);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(180deg, var(--black-deep) 0%, var(--black-primary) 100%);
            color: var(--white-soft);
            line-height: 1.7;
            overflow-x: hidden;
        }

        /* NAVBAR - MISMO QUE PRINCIPAL */
        .navbar {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background: var(--black-primary);
            padding: 1.2rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            z-index: 1000;
            backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(244, 226, 125, 0.2);
            transition: all 0.3s ease;
        }

        .logo-nav {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark), var(--gold-primary));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            text-shadow: 0 0 30px var(--gold-glow);
            animation: logoPulse 3s ease-in-out infinite;
        }

        @keyframes logoPulse {
            0%, 100% { transform: scale(1); filter: drop-shadow(0 0 10px var(--gold-glow)); }
            50% { transform: scale(1.05); filter: drop-shadow(0 0 25px var(--gold-glow)); }
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 2.5rem;
        }

        .social-nav {
            display: flex;
            gap: 1.5rem;
        }

        .social-nav a {
            color: var(--white-soft);
            font-size: 1.4rem;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }

        .social-nav a:hover {
            color: var(--gold-primary);
            transform: translateY(-3px) rotate(10deg);
            text-shadow: 0 0 15px var(--gold-glow);
        }

        .hamburger {
            display: flex;
            flex-direction: column;
            justify-content: space-around;
            width: 35px;
            height: 25px;
            cursor: pointer;
            z-index: 1001;
            transition: 0.3s;
        }

        .hamburger span {
            width: 100%;
            height: 4px;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            border-radius: 2px;
            transition: 0.3s;
            box-shadow: 0 2px 10px var(--gold-glow);
        }

        .hamburger.active span:nth-child(1) {
            transform: rotate(45deg) translate(8px, 8px);
        }

        .hamburger.active span:nth-child(2) {
            opacity: 0;
        }

        .hamburger.active span:nth-child(3) {
            transform: rotate(-45deg) translate(7px, -7px);
        }

        .mobile-menu {
            position: fixed;
            top: 80px;
            right: -350px;
            width: 350px;
            height: calc(100vh - 80px);
            background: linear-gradient(135deg, var(--black-primary), var(--black-deep));
            transition: right 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            padding: 3rem 2rem;
            z-index: 999;
            border-left: 1px solid rgba(244, 226, 125, 0.2);
        }

        .mobile-menu.active {
            right: 0;
        }

        .mobile-menu ul {
            list-style: none;
        }

        .mobile-menu li {
            margin: 2rem 0;
        }

        .mobile-menu a {
            color: var(--white-soft);
            text-decoration: none;
            font-size: 1.3rem;
            font-weight: 500;
            display: block;
            padding: 1rem 0;
            border-bottom: 1px solid rgba(244, 226, 125, 0.1);
            transition: all 0.3s ease;
        }

        .mobile-menu a:hover {
            color: var(--gold-primary);
            padding-left: 1.5rem;
            text-shadow: 0 0 15px var(--gold-glow);
        }

        /* HERO PRODUCTOS */
        .hero-productos {
            min-height: 70vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 140px 5% 80px;
            background: radial-gradient(ellipse at center, rgba(244, 226, 125, 0.1) 0%, transparent 70%);
        }

        .hero-title {
            font-size: 4.5rem;
            font-weight: 800;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark), var(--gold-primary));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 1.5rem;
            text-shadow: 0 0 40px var(--gold-glow);
        }

        .hero-subtitle {
            font-size: 1.6rem;
            max-width: 700px;
            opacity: 0.9;
        }

        /* SECCIÓN GRILLA PRODUCTOS PREMIUM */
        .productos-section {
            padding: 80px 5%;
            max-width: 1600px;
            margin: 0 auto;
        }

        .section-title {
            font-size: 3.8rem;
            text-align: center;
            margin-bottom: 5rem;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            text-shadow: 0 0 40px var(--gold-glow);
        }

        .productos-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 3.5rem;
            margin-bottom: 6rem;
        }

        /* TARJETAS PRODUCTOS PREMIUM */
        .producto-card {
            background: linear-gradient(145deg, rgba(10, 10, 10, 0.95), rgba(5, 5, 5, 0.85));
            backdrop-filter: blur(25px);
            border: 2px solid transparent;
            border-radius: 25px;
            padding: 2.5rem 2rem;
            text-align: center;
            position: relative;
            overflow: hidden;
            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 25px 70px rgba(0,0,0,0.6);
            cursor: pointer;
        }

        .producto-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(249, 226, 125, 0.15), transparent);
            transition: left 0.8s ease;
            z-index: 1;
        }

        .producto-card:hover::before {
            left: 100%;
        }

        .producto-card:hover {
            transform: translateY(-25px) scale(1.05);
            border-image: linear-gradient(135deg, var(--gold-primary), var(--gold-dark)) 1;
            border-color: transparent;
            box-shadow: 0 50px 120px rgba(249, 226, 125, 0.35);
        }

        .producto-imagen {
            width: 100%;
            height: 280px;
            border-radius: 20px;
            margin-bottom: 2rem;
            object-fit: cover;
            border: 2px solid rgba(249, 226, 125, 0.3);
            transition: all 0.4s ease;
            background: linear-gradient(135deg, rgba(249, 226, 125, 0.1), rgba(212, 175, 55, 0.1));
        }

        .producto-card:hover .producto-imagen {
            transform: scale(1.1);
            border-color: var(--gold-primary);
            box-shadow: 0 20px 50px rgba(249, 226, 125, 0.4);
        }

        /* PLACEHOLDER IMAGEN SI NO CARGA */
        .producto-placeholder {
            width: 100%;
            height: 280px;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 4rem;
            color: var(--black-primary);
            margin-bottom: 2rem;
            border: 2px solid var(--gold-primary);
        }

        .producto-titulo {
            font-size: 2.2rem;
            font-weight: 700;
            margin-bottom: 1rem;
            color: var(--white-soft);
            transition: all 0.3s ease;
        }

        .producto-card:hover .producto-titulo {
            color: var(--gold-primary);
            text-shadow: 0 0 20px var(--gold-glow);
        }

        .producto-precio {
            font-size: 2.8rem;
            font-weight: 900;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 2.5rem;
            text-shadow: 0 0 30px var(--gold-glow);
        }

        /* BOTÓN WHATSAPP DORADO */
        .btn-whatsapp {
            display: inline-flex;
            align-items: center;
            gap: 1rem;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            color: var(--black-primary);
            padding: 1.3rem 3rem;
            font-size: 1.3rem;
            font-weight: 700;
            text-decoration: none;
            border-radius: 50px;
            transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 15px 40px rgba(249, 226, 125, 0.5);
            position: relative;
            overflow: hidden;
        }

        .btn-whatsapp::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.6s;
        }

        .btn-whatsapp:hover::before {
            left: 100%;
        }

        .btn-whatsapp:hover {
            transform: translateY(-8px) scale(1.05);
            box-shadow: 0 25px 60px rgba(249, 226, 125, 0.7);
        }

        /* FILTROS CATEGORÍAS */
        .filtros {
            display: flex;
            justify-content: center;
            gap: 2rem;
            margin-bottom: 4rem;
            flex-wrap: wrap;
        }

        .filtro-btn {
            background: rgba(255,255,255,0.05);
            color: var(--white-soft);
            border: 2px solid rgba(249, 226, 125, 0.3);
            padding: 1rem 2.5rem;
            border-radius: 50px;
            cursor: pointer;
            font-weight: 600;
            transition: all 0.3s ease;
        }

        .filtro-btn.active,
        .filtro-btn:hover {
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            color: var(--black-primary);
            border-color: var(--gold-primary);
            box-shadow: 0 10px 30px rgba(249, 226, 125, 0.4);
        }

        /* FOOTER - MISMO QUE PRINCIPAL */
        .footer {
            background: var(--black-primary);
            padding: 6rem 5% 3rem;
            border-top: 2px solid transparent;
            border-image: linear-gradient(135deg, var(--gold-primary), var(--gold-dark)) 1;
        }

        .footer-content {
            max-width: 1400px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 4rem;
            margin-bottom: 3rem;
        }

        .footer-section h3 {
            color: var(--gold-primary);
            font-size: 1.8rem;
            margin-bottom: 2rem;
            text-shadow: 0 0 20px var(--gold-glow);
        }

        .siguenos-section {
            text-align: center;
        }

        .social-large {
            display: flex;
            justify-content: center;
            gap: 2.5rem;
            margin-top: 2rem;
        }

        .social-large a {
            width: 80px;
            height: 80px;
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2.2rem;
            color: var(--black-primary);
            text-decoration: none;
            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 15px 40px rgba(244, 226, 125, 0.4);
        }

        .social-large a:hover {
            transform: translateY(-15px) rotate(360deg) scale(1.1);
            box-shadow: 0 25px 60px rgba(244, 226, 125, 0.6);
        }

        .footer-bottom {
            text-align: center;
            padding-top: 3rem;
            border-top: 1px solid rgba(244, 226, 125, 0.2);
            color: rgba(255,255,255,0.7);
        }

        /* RESPONSIVE PARA CELULARES HULPÉN/CONCEPCIÓN */
        @media (max-width: 768px) {
            .hero-title { font-size: 3.2rem; }
            .section-title { font-size: 2.8rem; }
            .productos-grid { 
                grid-template-columns: 1fr; 
                gap: 2.5rem;
                max-width: 400px;
                margin: 0 auto;
            }
            .producto-card { 
                padding: 2rem 1.5rem; 
                margin: 0 1rem;
            }
            .producto-imagen, .producto-placeholder { 
                height: 250px; 
            }
            .filtros { 
                flex-direction: column; 
                align-items: center;
                gap: 1rem;
            }
            .navbar { padding: 1rem 3%; }
            .social-large { gap: 2rem; }
            .social-large a { width: 70px; height: 70px; font-size: 2rem; }
        }

        /* SCROLLBAR PERSONALIZADA */
        ::-webkit-scrollbar {
            width: 12px;
        }

        ::-webkit-scrollbar-track { background: var(--black-deep); }
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(135deg, var(--gold-primary), var(--gold-dark));
            border-radius: 6px;
        }
    </style>
</head>
